{
  "cleanUrls": true,

  "rewrites": [
    {
      "source": "/badge",
      "destination": "/"
    }
  ],

  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, immutable, max-age=31536000"
        }
      ]
    }
  ]
}